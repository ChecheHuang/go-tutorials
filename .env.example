# ==========================================================================
# 環境變數範本（Environment Variables Template）
# ==========================================================================
#
# 使用方式：
#   複製這個檔案並重新命名為 .env
#   cp .env.example .env
#
#   然後修改 .env 裡的值（.env 已加入 .gitignore，不會被提交到 Git）
#
# 注意：.env 檔案包含敏感資訊，絕對不能 commit 到版本控制！
# ==========================================================================

# ==========================================================================
# 伺服器設定
# ==========================================================================

# 伺服器監聽的埠號（預設 8080）
SERVER_PORT=8080

# Gin 框架模式：debug / release / test
# 開發時用 debug（會顯示詳細路由資訊），正式環境用 release
GIN_MODE=debug

# ==========================================================================
# 資料庫設定
# ==========================================================================

# SQLite 資料庫路徑（目前使用，開發環境推薦）
DB_DSN=./blog.db

# PostgreSQL 連線字串（未來升級時使用）
# 本地 Docker：
# DB_DSN=postgres://postgres:password@localhost:5432/blog?sslmode=disable
# Neon 雲端免費方案：
# DB_DSN=postgres://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# ==========================================================================
# JWT 設定
# ==========================================================================

# JWT 簽名密鑰（正式環境必須改成強密碼，至少 32 字元）
# 可以用以下指令產生隨機密鑰：
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret-in-production

# Token 有效期（格式：24h, 30m, 7 * 24h 等）
JWT_EXPIRATION=24h

# ==========================================================================
# Redis 設定（第 20 課開始需要）
# ==========================================================================

# 選項 A：本地 Docker（執行 docker-compose -f docker-compose.dev.yml up -d）
REDIS_URL=redis://localhost:6379

# 選項 B：Upstash 雲端免費方案（https://upstash.com）
# REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# 選項 C：本地安裝（brew install redis 或 apt install redis-server）
# REDIS_URL=redis://localhost:6379

# Redis 資料庫編號（0-15，預設 0）
REDIS_DB=0

# ==========================================================================
# 其他設定（未來擴充用）
# ==========================================================================

# 允許的跨域來源（正式環境應設定具體的網域）
# CORS_ORIGIN=https://your-frontend.com

# 日誌等級：debug / info / warn / error
# LOG_LEVEL=info

# 最大請求數（Rate Limiting 用）
# RATE_LIMIT_MAX=100
