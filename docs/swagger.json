    "definitions": {
        "domain.Article": {
            "type": "object",
            "properties": {
                "comments": {
                    "description": "文章的留言列表",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.Comment"
                    }
                },
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "title": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "user": {
                    "description": "關聯的使用者資料",
                    "allOf": [
                        {
                            "$ref": "#/definitions/domain.User"
                        }
                    ]
                },
                "user_id": {
                    "description": "作者 ID（外鍵）",
                    "type": "integer"
                }
            }
        },
        "domain.Comment": {
            "type": "object",
            "properties": {
                "article_id": {
                    "description": "所屬文章 ID（外鍵）",
                    "type": "integer"
                },
                "content": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                },
                "user": {
                    "description": "關聯的使用者資料",
                    "allOf": [
                        {
                            "$ref": "#/definitions/domain.User"
                        }
                    ]
                },
                "user_id": {
                    "description": "留言者 ID（外鍵）",
                    "type": "integer"
                }
            }
        },
        "domain.CreateArticleRequest": {
            "type": "object",
            "required": [
                "content",
                "title"
            ],
            "properties": {
                "content": {
                    "description": "文章內容（至少 1 字元）",
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "description": "文章標題（1-200 字元）",
                    "type": "string",
                    "maxLength": 200,
                    "minLength": 1
                }
            }
        },
        "domain.CreateCommentRequest": {
            "type": "object",
            "required": [
                "content"
            ],
            "properties": {
                "content": {
                    "description": "留言內容（1-1000 字元）",
                    "type": "string",
                    "maxLength": 1000,
                    "minLength": 1
                }
            }
        },
        "domain.LoginRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "description": "電子信箱",
                    "type": "string"
                },
                "password": {
                    "description": "密碼",
                    "type": "string"
                }
            }
        },
        "domain.LoginResponse": {
            "type": "object",
            "properties": {
                "token": {
                    "description": "JWT Token",
                    "type": "string"
                },
                "user": {
                    "description": "使用者資訊",
                    "allOf": [
                        {
                            "$ref": "#/definitions/domain.User"
                        }
                    ]
                }
            }
        },
        "domain.RegisterRequest": {
            "type": "object",
            "required": [
                "email",
                "password",
                "username"
            ],
            "properties": {
                "email": {
                    "description": "電子信箱",
                    "type": "string"
                },
                "password": {
                    "description": "密碼（至少 6 字元）",
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 6
                },
                "username": {
                    "description": "使用者名稱（3-50 字元）",
                    "type": "string",
                    "maxLength": 50,
                    "minLength": 3
                }
            }
        },
        "domain.UpdateArticleRequest": {
            "type": "object",
            "properties": {
                "content": {
                    "description": "文章內容（可選）",
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "description": "文章標題（可選）",
                    "type": "string",
                    "maxLength": 200,
                    "minLength": 1
                }
            }
        },
        "domain.UpdateCommentRequest": {
            "type": "object",
            "required": [
                "content"
            ],
            "properties": {
                "content": {
                    "description": "留言內容",
                    "type": "string",
                    "maxLength": 1000,
                    "minLength": 1
                }
            }
        },
        "domain.User": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "updated_at": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "response.PaginatedData": {
            "type": "object",
            "properties": {
                "items": {
                    "description": "資料列表"
                },
                "page": {
                    "description": "目前頁碼",
                    "type": "integer"
                },
                "page_size": {
                    "description": "每頁筆數",
                    "type": "integer"
                },
                "total": {
                    "description": "總筆數",
                    "type": "integer"
                },
                "total_pages": {
                    "description": "總頁數",
                    "type": "integer"
                }
            }
        },
        "response.Response": {
            "type": "object",
            "properties": {
                "code": {
                    "description": "HTTP 狀態碼",
                    "type": "integer"
                },
                "data": {
                    "description": "回應資料（可選）"
                },
                "message": {
                    "description": "回應訊息",
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "在此輸入 Bearer Token，格式：Bearer \u003ctoken\u003e",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}